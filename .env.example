# Tutoria Widget - Environment Variables
# Copy this file to .env for local development

# API Base URL - REQUIRED
# For local development, use localhost
PUBLIC_API_BASE_URL=http://localhost:8000

# For production, use your deployed API URL
# PUBLIC_API_BASE_URL=https://tutoria-api-dev.orangesmoke-8addc8f4.eastus2.azurecontainerapps.io

# Dark Mode (optional)
# Options: 'auto' (default), 'true', 'false'
# PUBLIC_ENABLE_DARK_MODE=auto

# ============================================
# IMPORTANT: Vercel Deployment Configuration
# ============================================
#
# The widget includes automatic fallback handling:
# If PUBLIC_API_BASE_URL is not set, it will automatically
# use: https://tutoria-api-dev.orangesmoke-8addc8f4.eastus2.azurecontainerapps.io
#
# For Vercel:
# 1. Go to Project Settings > Environment Variables
# 2. Add PUBLIC_API_BASE_URL with your API URL
# 3. Set for both Preview and Production environments
# 4. Redeploy for changes to take effect
#
# The widget now includes:
# - Automatic retry logic (up to 3 attempts)
# - Exponential backoff with jitter
# - 60-second timeout for AI responses
# - Connection keep-alive headers
# - User-friendly error messages
#
# Variables with PUBLIC_ prefix are exposed to the browser
# See: https://docs.astro.build/en/guides/environment-variables/
